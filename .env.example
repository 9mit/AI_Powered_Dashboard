# Environment Configuration - India Development Goals Dashboard

# Environment Type: development, production, testing
ENV=development

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ENABLE_CORS=true

# Data Configuration
DATA_CACHE_TIMEOUT=3600
DATA_REQUEST_TIMEOUT=15
MAX_RETRIES=3

# Logging
LOG_LEVEL=INFO
LOG_FILE=app.log

# Security
SESSION_TIMEOUT=1800
DEBUG=false

# Performance
CACHE_ENABLED=true
MAX_CACHE_ENTRIES=1000
